# OurHangout OpenClaw custom channel device env example
#
# This example is for the current dev environment.
# Dev backend / websocket:
#   http://wowjini0228.synology.me:7084
#   ws://wowjini0228.synology.me:7084/v1/openclaw/channel/ws
#
# Copy this file to `.env`, replace the pairing code, then run:
#   npm run channel:setup
#   npm run channel:doctor
#   openclaw gateway restart
#   npm run channel:smoke

# Required: backend base URL used for channel register/sync/outbound APIs.
OURHANGOUT_SERVER_BASE_URL=http://wowjini0228.synology.me:7084

# Required in the current dev setup because websocket must use the dev gateway path directly.
OPENCLAW_CHANNEL_WS_URL=ws://wowjini0228.synology.me:7084/v1/openclaw/channel/ws

# Required: generate this in the app from the target Pobi profile.
OPENCLAW_CHANNEL_PAIRING_CODE=YOUR_PAIRING_CODE_FROM_APP

# Optional: OpenClaw config file location.
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# Optional: OpenClaw agent id whose auth store should be checked by channel:doctor.
OPENCLAW_AGENT_ID=main

# Optional: account alias written into channels.ourhangout.accounts.<alias>.
OPENCLAW_CHANNEL_ACCOUNT_ALIAS=default

# Optional but recommended: stable device identity shown on the server.
OPENCLAW_CHANNEL_DEVICE_KEY=raspi-openclaw-1
OPENCLAW_CHANNEL_DEVICE_NAME=Living Room Pi
OPENCLAW_CHANNEL_PLATFORM=linux

# Optional: channel poll fallback interval in milliseconds.
OPENCLAW_CHANNEL_POLL_INTERVAL_MS=3000

# Optional: persisted sync cursor/state directory.
OPENCLAW_CHANNEL_STATE_DIR=~/.openclaw/state/ourhangout

# Important:
# ourhangout only adds the chat channel. OpenClaw still needs a working LLM provider
# for the agent that handles replies. If your default model uses Anthropic, make sure
# ~/.openclaw/agents/main/agent/auth-profiles.json or ~/.openclaw/.env contains valid auth.
