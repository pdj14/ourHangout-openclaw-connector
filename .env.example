# ---------------------------------------------------------------------------
# OurHangout OpenClaw device env example
# Server base URL used in this workspace:
#   http://wowjini0228.synology.me:7083
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Recommended path: OurHangout custom channel plugin
# ---------------------------------------------------------------------------

OURHANGOUT_SERVER_BASE_URL=http://wowjini0228.synology.me:7083
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
OPENCLAW_CHANNEL_ACCOUNT_ALIAS=default

# Generate this in the app from the target Pobi profile.
OPENCLAW_CHANNEL_PAIRING_CODE=YOUR_PAIRING_CODE_FROM_APP

OPENCLAW_CHANNEL_DEVICE_KEY=raspi-openclaw-1
OPENCLAW_CHANNEL_DEVICE_NAME=Living Room Pi
OPENCLAW_CHANNEL_PLATFORM=linux
OPENCLAW_CHANNEL_POLL_INTERVAL_MS=3000
OPENCLAW_CHANNEL_STATE_DIR=~/.openclaw/state/ourhangout

# ---------------------------------------------------------------------------
# Legacy bridge fallback
# Keep only if you still want the old connector.mjs path available.
# ---------------------------------------------------------------------------

HUB_WS_URL=ws://wowjini0228.synology.me:7084/v1/openclaw/connector/ws

# First run only: generate this in the app if you use the legacy bridge path.
PAIRING_CODE=

CONNECTOR_ID=raspi-openclaw-1
CONNECTOR_DEVICE_NAME=Living Room Pi

# Optional manual override. Normally leave empty and let the script save/load it.
CONNECTOR_AUTH_TOKEN=
CONNECTOR_AUTH_TOKEN_FILE=./connector-auth-token.txt
CONNECTOR_LOCK_FILE=./connector.lock

CONNECTOR_MODE=http
OPENCLAW_LOCAL_BASE_URL=http://127.0.0.1:18789
CONNECTOR_RECONNECT_MS=3000
CONNECTOR_REQUEST_TIMEOUT_MS=4000
